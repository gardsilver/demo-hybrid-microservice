# Значения по умолчанию, применяемые автоматически при отсутствии .env
# Минимальная конфигурация для локального запуска без Docker

# ==== НАСТРОЙКИ МИКРОСЕРВИСА ====
SERVICE_PORT=3000
CORS_OPTIONS={"origin":"*"}

# ==== НАСТРОЙКИ ЛОГИРОВАНИЯ ====
LOGGER_FORMAT_RECORD=FULL

# ==== НАСТРОЙКИ PROMETHEUS ====
APPLICATION_NAME=demo-hybrid-microservice
MICROSERVICE_NAME=demo
MICROSERVICE_VERSION=1.0.0

# ==== НАСТРОЙКИ БД ====
DATABASE_MIGRATIONS_ENABLED=no
DATABASE_LOGGING_ENABLED=no
