# ===================================================================================
# Конфигурация Demo Hybrid Microservice
#
# Перечислены ВСЕ параметры окружения с описаниями, допустимыми значениями и примерами.
# При копировании в .env без изменений — проект запустится в окружении
# deploy/base-compose.yml со значениями по умолчанию.
# ===================================================================================


# ====================================================================================
#  НАСТРОЙКИ МИКРОСЕРВИСА
#  @see src/core/app/services/app.config.ts
# ====================================================================================

# Порт HTTP-сервера (Swagger, REST API, WebSocket).
# Тип: number. По умолчанию: 3000
SERVICE_PORT=3000

# Хост gRPC-сервера.
# Тип: string. По умолчанию: 0.0.0.0
GRPC_HOST=0.0.0.0

# Порт gRPC-сервера (Reflection Service).
# Тип: number. Если не задан — gRPC-сервер не запускается.
GRPC_PORT=3001

# CORS-настройки в формате JSON.
# Тип: JSON-строка. По умолчанию: {"origin":"*"}
# Пример: CORS_OPTIONS={"origin":"https://example.com","credentials":true}
CORS_OPTIONS={"origin":"*"}


# ====================================================================================
#  НАСТРОЙКИ ПОДКЛЮЧЕНИЯ К БД POSTGRES
#  @see src/modules/database/services/database.config.ts
# ====================================================================================

# Хост сервера БД.
# Тип: string.
DATABASE_HOST=postgresdb

# Порт сервера БД.
# Тип: number.
DATABASE_PORT=5432

# Диалект подключения.
# Тип: string. Возможные значения: postgres, mysql, sqlite, mariadb, mssql
DATABASE_DIALECT=postgres

# Имя базы данных.
# Тип: string.
DATABASE_NAME=demo

# Схема подключения.
# Тип: string.
DATABASE_SCHEMA=public

# Имя пользователя БД.
# Тип: string.
DATABASE_USER=vagrant

# Пароль пользователя БД.
# Тип: string.
DATABASE_PASSWORD=vagrant

# Префикс для имени таблицы миграций.
# Тип: string. Необязательный.
DATABASE_PREFIX=

# Имя таблицы миграций.
# Тип: string. По умолчанию: migrations
DATABASE_MIGRATIONS_TABLE=migrations

# Автоматическое применение миграций при запуске.
# Значения: yes | no (без учёта регистра). По умолчанию: no
DATABASE_MIGRATIONS_ENABLED=yes

# Логирование SQL-запросов.
# Значения: yes | no (без учёта регистра). По умолчанию: no
DATABASE_LOGGING_ENABLED=no


# ====================================================================================
#  НАСТРОЙКИ REDIS CACHE MANAGER
#  @see src/modules/redis-cache-manager/services/redis-cache-manager.config.ts
# ====================================================================================

# Хост сервера Redis.
# Тип: string. По умолчанию: redis
REDIS_CACHE_MANAGER_HOST=redis

# Порт сервера Redis.
# Тип: number. По умолчанию: 6379
REDIS_CACHE_MANAGER_PORT=6379

# TTL записи в кеше (мс).
# Тип: number. По умолчанию: 600000 (10 минут)
REDIS_CACHE_MANAGER_TTL=600000

# Максимальная пауза между попытками восстановления соединения (мс).
# Тип: number. По умолчанию: 1200000 (20 минут)
REDIS_CACHE_MANAGER_MAX_DELAY_BEFORE_RECONNECT=1200000

# Количество неудачных попыток восстановления соединения до сброса стратегии.
# Тип: number. По умолчанию: 200
REDIS_CACHE_MANAGER_COUNT_FOR_RESET_RECONNECT_STRATEGY=200


# ====================================================================================
#  НАСТРОЙКИ KAFKA
#  @see src/core/app/services/app.kafka.config.ts
# ====================================================================================

# Список брокеров Kafka (через запятую).
# Тип: string (CSV). Пример: kafka:9092,kafka2:9092
KAFKA_BROKERS=kafka:9092

# Идентификатор Kafka-клиента.
# Тип: string.
KAFKA_CLIENT_ID=demo-hybrid-microservice

# Идентификатор группы Kafka-консьюмеров.
# Тип: string.
KAFKA_GROUP_ID=demo-hybrid-microservice-group

# Статус-коды, при которых producer выполнит повторную отправку (через запятую).
# Тип: string (CSV). Пример: 3,14
KAFKA_RETRY_STATUS_CODES=


# ====================================================================================
#  НАСТРОЙКИ RABBITMQ
#  @see src/core/app/services/app.rabbit-mq.config.ts
# ====================================================================================

# Список URL для подключения (через запятую).
# Тип: string (CSV). Пример: rabbitmq:5672,rabbitmq2:5672
RABBIT_MQ_URLS=rabbitmq:5672

# Имя пользователя RabbitMQ.
# Тип: string.
RABBIT_MQ_USER=admin

# Пароль пользователя RabbitMQ.
# Тип: string.
RABBIT_MQ_PASSWORD=admin


# ====================================================================================
#  НАСТРОЙКИ ЛОГИРОВАНИЯ (ElkLogger Module)
#  @see src/modules/elk-logger/services/elk-logger.config.ts
# ====================================================================================

# Формат вывода лога.
# Значения:
#   FULL   — полный лог в формате JSON (для production / ElasticSearch)
#   SIMPLE — сжатый лог с цветовой схемой (для локальной разработки)
#   SHORT  — максимально сжатый лог с цветовой схемой
#   NULL   — не выводить логи
# По умолчанию: FULL
LOGGER_FORMAT_RECORD=FULL

# Список модулей, логи которых игнорируются (через запятую).
# Регистр имеет значение. Пример: app,NestFactory
LOGGER_IGNORE_MODULES=

# Уровни логирования (через запятую).
# Значения: TRACE, DEBUG, INFO, WARN (без учёта регистра).
# Если не задан — пишутся все уровни.
LOGGER_LEVELS=

# Формат поля timestamp.
# Тип: string. По умолчанию: YYYY-MM-DDTHH:mm:ssZ
# Пример: DD.MM.YYYY HH:mm:ss
LOGGER_FORMAT_TIMESTAMP=

# Путь к файлу для записи логов. Работает только при LOGGER_FORMAT_RECORD=SHORT.
# Тип: string. Пример: log.log
LOGGER_STORE_FILE=


# --- Настройки сжатия логов (Prune) ---
# @see src/modules/elk-logger/formatters/prune.config.ts

# Включение сжатия объёма логов.
# Значения:
#   NO           — не применять (без учёта регистра)
#   YES          — обрезать до длины --default-- из LOGGER_PRUNE_MAX_LENGTH_FIELDS
#   <имя_поля>   — обрезать до длины указанного поля из LOGGER_PRUNE_MAX_LENGTH_FIELDS
# По умолчанию: NO
LOGGER_PRUNE_ENABLED=NO

# Максимальное количество полей в IKeyValue.
# Тип: number. Значение 0 — без ограничений. По умолчанию: 0
LOGGER_PRUNE_MAX_FIELDS=0

# Максимальная глубина вложенности данных.
# Тип: number. Значение 0 — без ограничений. По умолчанию: 0
LOGGER_PRUNE_MAX_DEPTH=0

# Форматы логов, к которым применять сжатие (через запятую).
# Значения: FULL, SIMPLE, SHORT, NULL. Пример: FULL,SHORT
LOGGER_PRUNE_APPLY_FOR_FORMATS=

# Максимальная длина полей (через запятую, формат: имя=длина).
# Служебные имена: --default-- (общий лимит), --array-- (лимит для массивов).
# Значение <= 0 — отключает лимит для данного поля.
# Пример: --array--=2,--default--=40,fileBody=20
LOGGER_PRUNE_MAX_LENGTH_FIELDS=


# ====================================================================================
#  НАСТРОЙКИ PROMETHEUS
#  @see src/modules/prometheus/services/prometheus.config.ts
# ====================================================================================

# Имя приложения (метка application во всех метриках).
# Тип: string.
APPLICATION_NAME=demo-hybrid-microservice

# Имя микросервиса (метка microservice во всех метриках).
# Тип: string.
MICROSERVICE_NAME=demo

# Версия микросервиса (метка version во всех метриках).
# Тип: string.
MICROSERVICE_VERSION=1.0.0


# ====================================================================================
#  НАСТРОЙКИ GRACEFUL SHUTDOWN
#  @see src/modules/graceful-shutdown/services/graceful-shutdown.config.ts
# ====================================================================================

# Включение плавного завершения приложения.
# Значения: yes | no (без учёта регистра). По умолчанию: no
GRACEFUL_SHUTDOWN_ENABLED=yes

# Таймаут этапа BEFORE_DESTROY (мс). Остановка консьюмеров, прекращение приёма запросов.
# Тип: number. По умолчанию: 10000
GRACEFUL_SHUTDOWN_TIMEOUT_ON_BEFORE_DESTROY=10000

# Таймаут этапа DESTROY (мс). Ожидание завершения активных процессов.
# Тип: number. По умолчанию: 30000
GRACEFUL_SHUTDOWN_TIMEOUT_ON_DESTROY=30000

# Таймаут этапа AFTER_DESTROY (мс). Финальная очистка.
# Тип: number. По умолчанию: 10000
GRACEFUL_SHUTDOWN_TIMEOUT_ON_AFTER_DESTROY=10000

# Пауза перед завершением процесса (мс). Даёт время сборщикам логов/метрик.
# Тип: number. По умолчанию: 15000
GRACEFUL_SHUTDOWN_GRACE_PERIOD=15000

# Сигнал, запускающий процесс плавного завершения.
# Тип: string. По умолчанию: SIGTERM
# Возможные значения: SIGTERM, SIGINT, SIGHUP и др.
GRACEFUL_SHUTDOWN_DESTROY_SIGNAL=SIGTERM


# ====================================================================================
#  НАСТРОЙКИ HTTP-КЛИЕНТА
#  @see src/modules/http/http-client/services/http-client.config.service.ts
# ====================================================================================

# Включение повторной отправки HTTP-запросов.
# Значения: yes | no (без учёта регистра). По умолчанию: no
HTTP_CLIENT_RETRY_ENABLED=yes

# Таймаут одного HTTP-запроса (мс).
# Тип: number. По умолчанию: 15000
HTTP_CLIENT_REQUEST_TIMEOUT=15000

# Общий таймаут процесса переотправки (мс).
# Тип: number. По умолчанию: 120000
HTTP_CLIENT_RETRY_TIMEOUT=120000

# Пауза между повторными запросами (мс).
# Тип: number. По умолчанию: 5000
HTTP_CLIENT_RETRY_DELAY=5000

# Максимальное количество повторных запросов.
# Тип: number. По умолчанию: 5
HTTP_CLIENT_RETRY_MAX_COUNT=5

# Статус-коды / ошибки, при которых выполняется повторный запрос (через запятую).
# По умолчанию: 408,502,503,504,ECONNABORTED,ETIMEDOUT,ECONNREFUSED,ECONNRESET
HTTP_CLIENT_RETRY_STATUS_CODES=408,502,503,504,ECONNABORTED,ETIMEDOUT,ECONNREFUSED,ECONNRESET


# ====================================================================================
#  НАСТРОЙКИ gRPC-КЛИЕНТА
#  @see src/modules/grpc/grpc-client/services/grpc-client.config.service.ts
# ====================================================================================

# Включение повторной отправки gRPC-запросов.
# Значения: yes | no (без учёта регистра). По умолчанию: no
GRPC_CLIENT_RETRY_ENABLED=yes

# Таймаут одного gRPC-запроса (мс).
# Тип: number. По умолчанию: 15000
GRPC_CLIENT_REQUEST_TIMEOUT=15000

# Общий таймаут процесса переотправки (мс).
# Тип: number. По умолчанию: 120000
GRPC_CLIENT_RETRY_TIMEOUT=120000

# Пауза между повторными запросами (мс).
# Тип: number. По умолчанию: 5000
GRPC_CLIENT_RETRY_DELAY=5000

# Максимальное количество повторных запросов.
# Тип: number. По умолчанию: 5
GRPC_CLIENT_RETRY_MAX_COUNT=5

# gRPC-статусы, при которых выполняется повторный запрос (через запятую).
# 4 = DEADLINE_EXCEEDED, 14 = UNAVAILABLE, timeout = таймаут
# По умолчанию: 4,14,timeout
GRPC_CLIENT_RETRY_STATUS_CODES=4,14,timeout
