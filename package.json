{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint:all": "eslint \"{src,migrations,tests}/**/*.ts\" --fix",
    "lint:diff": "grep -E '\\.(t|j)s$' .eslint-list | xargs eslint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./jest-e2e.json",
    "proto-compile": "node compile-protos.js",
    "proto-compile-win": "node compile-protos.js win",
    "migrate:generate": "npx sequelize-cli migration:generate --name "
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/microservices": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.7",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.18",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^1.0.3",
    "axios": "^1.15.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "fishery": "^2.4.0",
    "grpc-health-check": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-deepmerge": "^7.0.3",
    "ts-proto": "^2.11.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@nestjs/cli": "^11.0.19",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.18",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@types/amqplib": "^0.10.8",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "jest": {
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/src/$1",
      "^tests/(.*)$": "<rootDir>/tests/$1",
      "^protos/compiled/(.*)$": "<rootDir>/protos/compiled/$1"
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "setupFiles": [
      "reflect-metadata",
      "<rootDir>/tests/jest.setup.ts"
    ],
    "coveragePathIgnorePatterns": [
      ".*\\.e2e-spec\\.ts$",
      "protos",
      "front",
      "dist",
      "node_modules",
      "coverage",
      "migrations"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(@faker-js/faker|ts-deepmerge|kafkajs)/)"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
